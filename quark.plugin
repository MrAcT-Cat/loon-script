#!name=夸克自动签到
#!desc=自动获取Cookie + 每日自动签到
#!author=Qi Shen

[Script]

# 获取 Cookie（打开夸克触发）
http-request ^https:\/\/.*quark\.cn\/api\/.* script-path=https://raw.githubusercontent.com/MrAcT-Cat/loon-script/main/quark_cookie.js, requires-body=false, timeout=10, tag=夸克获取Cookie

# 自动签到（每天9点）
cron "0 9 * * *" script-path=https://raw.githubusercontent.com/MrAcT-Cat/loon-script/main/quark_sign.js, timeout=60, tag=夸克签到

[MITM]
hostname = scan-order.quark.cn