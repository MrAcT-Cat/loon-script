[MITM]
hostname = scan-order.quark.cn

[Rule]
HOST-SUFFIX, scan-order.quark.cn, QuarkScan

[Script]
# 夸克Cookie自动抓取
QuarkScan_CookieGrab = type=http-request, pattern=^https://scan-order\.quark\.cn/api/.*, script-path=https://你的仓库地址/loon-script/quark_cookie.js, requires-body=false, enable=true

# 夸克每日定时签到（每天0点执行）
QuarkScan每日签到 = type=cron, script-path=https://你的仓库地址/loon-script/quark_sign.js, cron=0 0 * * *, timeout=60, enable=true