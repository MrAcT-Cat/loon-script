[General]
; 夸克网盘签到插件配置

[MitM]
hostname = drive-m.quark.cn

[Script]
; 抓包脚本（开启一次后可关闭）
type=http-response,pattern=^https?://drive-m\.quark\.cn/1/clouddrive/capacity/growth/.*,script-path=https://raw.githubusercontent.com/你的用户名/loon-script/main/quark_cookie.js,tag=夸克请求捕获

; 自动签到定时脚本（每天08:00执行）
type=cron,cronexp=0 0 8 * * *,script-path=https://raw.githubusercontent.com/你的用户名/loon-script/main/quark_sign.js,tag=夸克自动签到