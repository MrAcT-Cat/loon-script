[MITM]
hostname = api.diveplus.cn

[Script]
http-response ^https://api\.diveplus\.cn/1\.1/functions/App\.GetUserInfo script-path=https://raw.githubusercontent.com/liul0ng/quanx/refs/heads/main/dive.js, requires-body=true