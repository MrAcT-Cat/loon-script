#!name=LoveKey 无限使用解锁
#!desc=适配1.8.2版本，解除聊天次数限制
#!author=convert
#!version=1.0
#!system=ios
#!category=功能解锁

[MITM]
hostname = sea.api.lovekeyboard.com

[Script]
# 聊天接口 请求头脚本
http-request https://sea.api.lovekeyboard.com/v1/chat/keyboard-stream-msg script-path=https://raw.githubusercontent.com/Yu9191/Rewrite/refs/heads/main/lovekey.js
# 开场白 请求头脚本
http-request https://sea.api.lovekeyboard.com/v1/chat/keyboard-ow-msg script-path=https://raw.githubusercontent.com/Yu9191/Rewrite/refs/heads/main/lovekey.js
# 超级对话 请求头脚本
http-request https://sea.api.lovekeyboard.com/v1/chat/stream_super_msg script-path=https://raw.githubusercontent.com/Yu9191/Rewrite/refs/heads/main/lovekey.js
# 账号信息 响应体篡改
http-response https://sea.api.lovekeyboard.com/v2/account script-path=https://raw.githubusercontent.com/Yu9191/Rewrite/refs/heads/main/lovekey.js, requires-body=true