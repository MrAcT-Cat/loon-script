#!name=赵家坊-启动广告屏蔽
#!desc=拦截开屏广告配置接口与广告素材，消除APP启动弹窗广告；明文HTTP接口无需MITM，HTTPS素材依靠MITM解密精准拦截
#!author=Custom
#!tag=去广告
#!loon_version=3.2.1(372)
#!type=normal

[rewrite]
# HTTP广告接口，明文无需MITM，返回空JSON
^http://api-pl-mobile\.zhaojiafang\.com/api/adv/adv_list reject-dict
# HTTPS广告图片素材，依靠MITM解密识别路径，返回空白1px图片
^https://qiniu\.zhaojiafang\.com/data/upload/shop/adv reject-img

[mitm]
hostname = qiniu.zhaojiafang.com