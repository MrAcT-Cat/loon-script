#!name=赵家坊-启动广告屏蔽
#!desc=拦截开屏广告配置接口与广告素材，消除APP启动弹窗广告；rewrite优先执行，不受DOMAIN分流规则干扰
#!author=Custom
#!tag=去广告
#!loon_version=3.2.1(372)
#!type=normal

[rewrite]
# 广告配置接口1
^http://api-pl-mobile\.zhaojiafang\.com/api/adv/adv_list reject-dict
# 新增广告配置接口2（抓包发现的appconfig）
^http://api\.zhaojiafang\.com/v1/fragment/appconfig reject-dict
# HTTPS广告图片素材 返回空白1px图片
^https://qiniu\.zhaojiafang\.com/data/upload/shop/adv reject-img

[mitm]
hostname = qiniu.zhaojiafang.com