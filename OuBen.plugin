[Rewrite]
^http://gdey\.ruijiadashop\.cn/api/card/getNotice url-script=notice_modify.js
^https?://ww\.ruijiadashop\.cn/.* reject

[Script]
notice_modify.js = type=http-response, pattern=^http://gdey\.ruijiadashop\.cn/api/card/getNotice, script-path=https://raw.githubusercontent.com/MrAcT-Cat/loon-script/main/notice_modify.js, requires-body=true, timeout=10, tag=启动广告修改

[MITM]
hostname = gdey.ruijiadashop.cn, ww.ruijiadashop.cn